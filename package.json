{
  "name": "image-shift",
  "version": "0.1.0",
  "private": true,
  "description": "Local Windows desktop app for image conversion, compression, background removal, layout matching, cropping, and resizing.",
  "author": "Codex",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev",
    "desktop:dev": "concurrently \"npm run dev\" \"wait-on tcp:3000 && cross-env NODE_ENV=development electron .\"",
    "build": "next build",
    "typecheck": "tsc --noEmit",
    "lint": "next lint",
    "test": "vitest run",
    "desktop:build:dir": "npm run build && electron-builder --win dir",
    "desktop:build:win": "npm run build && electron-builder --win nsis",
    "desktop:build:portable": "npm run build && electron-builder --win portable"
  },
  "dependencies": {
    "@imgly/background-removal-node": "^1.4.5",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/node": "22.13.10",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "autoprefixer": "10.4.20",
    "concurrently": "9.1.2",
    "cross-env": "7.0.3",
    "electron": "35.1.5",
    "electron-builder": "25.1.8",
    "eslint": "9.20.1",
    "eslint-config-next": "15.2.0",
    "next": "^15.2.6",
    "postcss": "8.5.3",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "tailwindcss": "3.4.17",
    "typescript": "5.8.2",
    "vitest": "3.0.8",
    "wait-on": "8.0.3"
  },
  "build": {
    "appId": "com.imageshift.app",
    "productName": "Image-Shift",
    "directories": {
      "output": "release"
    },
    "afterPack": "scripts/after-pack.cjs",
    "files": [
      "electron/**/*",
      "out/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/@imgly/background-removal-node/dist/**/*",
      "node_modules/@imgly/background-removal-node/node_modules/sharp/**/*",
      "node_modules/onnxruntime-node/**/*"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "artifactName": "${productName} Setup ${version}.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Image-Shift"
    }
  }
}
